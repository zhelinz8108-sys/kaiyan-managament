{
  "name": "hotel-apartment-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "db:init": "tsx scripts/init-db.ts",
    "db:reset": "tsx scripts/init-db.ts --reset",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:200": "tsx prisma/seed.ts --rooms 200",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^8.1.1",
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "nanoid": "^5.1.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "prisma": "^6.7.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
