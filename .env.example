DATABASE_URL="file:./dev.db"

# 首个后台管理员引导账号。数据库里还没有管理员时，应用启动会自动创建。
WEB_ADMIN_USERNAME=""
WEB_ADMIN_PASSWORD=""
WEB_ADMIN_DISPLAY_NAME="凯燕管理员"
WEB_ADMIN_SESSION_DAYS="14"

# 可选值：
# - auto: 仅在 HTTPS 请求下自动追加 Secure Cookie
# - true / always: 始终追加 Secure
# - false / never: 不追加 Secure
WEB_ADMIN_COOKIE_SECURE="auto"

PORT=3000
FRONTDESK_DEMO_PASSWORD="frontdesk123"

# SQLite 备份保留策略
SQLITE_BACKUP_KEEP_COUNT="30"
SQLITE_BACKUP_DIR="prisma/backups"
